{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist-api",
    "types": ["node"]
  },
  "include": ["api/**/*.ts", "middleware/**/*.ts", "utils/**/*.ts"]
}
